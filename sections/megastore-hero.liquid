<style>
/* ─── Base Styles ─── */
.moh-section {
  position: relative;
  overflow: hidden;
  background: #1a1030;
  color: #ffffff;
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  box-sizing: border-box;
}
.moh-section *, .moh-section *::before, .moh-section *::after { box-sizing: border-box; }

.moh-progress-bar {
  position: absolute;
  top: 0; left: 0; height: 4px;
  background: #fc2779;
  width: 0%; z-index: 100;
  transition: width linear;
}

.moh-slider-outer { overflow: hidden; width: 100%; position: relative; }
.moh-track {
  display: flex;
  transition: transform 0.6s cubic-bezier(0.645, 0.045, 0.355, 1);
  will-change: transform;
  width: 100%;
}

.moh-slide {
  flex: 0 0 100%;
  width: 100%;
  padding: 50px 0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  min-height: 480px;
}

/* ─── Vibrant Effect Gradients ─── */
.moh-slide-1 { background: linear-gradient(135deg, #101820 0%, #232f3e 100%); }
.moh-slide-2 { background: linear-gradient(135deg, #003399 0%, #2874f0 100%); }
.moh-slide-3 { background: linear-gradient(135deg, #7b1fa2 0%, #fc2779 100%); }
.moh-slide-4 { background: linear-gradient(135deg, #c2185b 0%, #ff5252 100%); }
.moh-slide-5 { background: linear-gradient(135deg, #003580 0%, #006aff 100%); }
.moh-slide-6 { background: linear-gradient(135deg, #9b1b30 0%, #d32f2f 100%); }
.moh-slide-7 { background: linear-gradient(135deg, #1b5e20 0%, #43a047 100%); }
.moh-slide-8 { background: linear-gradient(135deg, #0d47a1 0%, #1976d2 100%); }
.moh-slide-9 { background: linear-gradient(135deg, #e65100 0%, #f57c00 100%); }
.moh-slide-10 { background: linear-gradient(135deg, #b71c1c 0%, #c62828 100%); }
.moh-slide-11 { background: linear-gradient(135deg, #004d40 0%, #00695c 100%); }
.moh-slide-12 { background: linear-gradient(135deg, #4527a0 0%, #673ab7 100%); }

.moh-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
  width: 100%;
}

.moh-content-left { flex: 1; max-width: 600px; text-align: left; }
.moh-content-right { flex-shrink: 0; }

.moh-badge {
  display: inline-block;
  padding: 6px 14px;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(5px);
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 50px;
  font-size: 11px; font-weight: 700;
  letter-spacing: 1px; margin-bottom: 20px;
  color: #fff; text-transform: uppercase;
}

.moh-title {
  font-size: clamp(26px, 4.5vw, 50px);
  font-weight: 900; line-height: 1.1;
  margin: 0 0 16px; color: #ffffff;
  text-shadow: 0 2px 10px rgba(0,0,0,0.2);
}
.moh-hl { color: #ffeb3b; text-shadow: 0 0 15px rgba(255, 235, 59, 0.4); }

.moh-subtitle {
  font-size: 17px; line-height: 1.6;
  color: rgba(255,255,255,0.9); margin-bottom: 30px;
  max-width: 500px;
}
.moh-subtitle strong { color: #fff; border-bottom: 2px solid #ffeb3b; }

.moh-stats { display: flex; gap: 30px; margin-bottom: 30px; }
.moh-stat-item span { font-size: 26px; font-weight: 900; color: #ffffff; display: block; line-height: 1; margin-bottom: 4px; }
.moh-stat-item small { font-size: 12px; color: rgba(255,255,255,0.6); text-transform: uppercase; }

.moh-cta {
  display: inline-flex; align-items: center; gap: 10px;
  background: #ffffff; color: #1a1030;
  padding: 16px 36px; border-radius: 14px;
  font-weight: 800; text-decoration: none;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  box-shadow: 0 10px 30px rgba(0,0,0,0.15);
}
.moh-cta:hover { transform: translateY(-5px) scale(1.02); background: #ffeb3b; color: #1a1030; box-shadow: 0 20px 40px rgba(255, 235, 59, 0.3); }

.moh-brand-showcase {
  background: #fff; padding: 30px;
  border-radius: 32px; border: 1px solid rgba(0,0,0,0.05);
  box-shadow: 0 20px 40px rgba(0,0,0,0.15);
  text-align: center;
}
.moh-logo-wrap {
  width: 180px; height: 90px;
  background: #fff; border: 1px solid #f0f0f0;
  border-radius: 16px; margin-bottom: 15px;
  display: flex; align-items: center; justify-content: center; padding: 15px;
}
.moh-logo-wrap img { max-width: 100%; max-height: 100%; object-fit: contain; }
.moh-offer-label { font-weight: 800; color: #1a1030; font-size: 15px; }

/* ─── Navigation ─── */
.moh-nav {
  position: absolute; top: 50%; transform: translateY(-50%);
  width: 50px; height: 50px; 
  background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3);
  backdrop-filter: blur(10px);
  border-radius: 50%; color: #ffffff;
  cursor: pointer; z-index: 10;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.3s; box-shadow: 0 4px 15px rgba(0,0,0,0.1);
}
.moh-nav:hover { background: #fc2779; color: #fff; border-color: #fc2779; transform: translateY(-50%) scale(1.1); box-shadow: 0 0 20px rgba(252, 39, 121, 0.4); }
.moh-prev { left: 20px; }
.moh-next { right: 20px; }

.moh-dots {
  position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%);
  display: flex; gap: 10px; z-index: 10;
}
.moh-dot {
  width: 10px; height: 10px; border-radius: 50%;
  background: rgba(255,255,255,0.25); border: none; cursor: pointer;
  padding: 0; transition: all 0.3s;
}
.moh-dot.is-active { background: #fc2779; width: 30px; border-radius: 5px; box-shadow: 0 0 15px rgba(252, 39, 121, 0.5); }

/* ─── Mobile ─── */
@media (max-width: 1024px) {
  .moh-container { flex-direction: column; text-align: center; gap: 30px; padding: 0 24px; }
  .moh-content-left { width: 100%; display: flex; flex-direction: column; align-items: center; max-width: 100%; }
  .moh-nav { display: none; }
  .moh-slide { padding: 30px 0; min-height: 400px; }
  .moh-stats { justify-content: center; gap: 20px; }
}
@media (max-width: 640px) {
  .moh-title { font-size: 26px; }
  .moh-subtitle { font-size: 14px; margin-bottom: 24px; }
  .moh-logo-wrap { width: 150px; height: 75px; }
  .moh-stat-item span { font-size: 22px; }
  .moh-cta { padding: 14px 28px; width: 100%; justify-content: center; font-size: 14px; }
  .moh-slide { min-height: 360px; }
}
</style>

<script>
(function() {
  const SEC_ID = '{{ section.id }}';
  const track = document.getElementById('moh-track-' + SEC_ID);
  const dots = document.querySelectorAll('#moh-dots-' + SEC_ID + ' .moh-dot');
  const prog = document.getElementById('moh-progress-' + SEC_ID);
  let current = 0;
  const total = 12;
  const delay = 5000;
  let interval;

  function update() {
    if (!track) return;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((dot, idx) => dot.classList.toggle('is-active', idx === current));
    resetProgress();
  }

  function resetProgress() {
    if (!prog) return;
    prog.style.transition = 'none';
    prog.style.width = '0%';
    setTimeout(() => {
      prog.style.transition = `width ${delay}ms linear`;
      prog.style.width = '100%';
    }, 50);
  }

  function next() { current = (current + 1) % total; update(); }
  function prev() { current = (current - 1 + total) % total; update(); }

  const nextBtn = document.getElementById('moh-next-' + SEC_ID);
  const prevBtn = document.getElementById('moh-prev-' + SEC_ID);

  if (nextBtn) nextBtn.addEventListener('click', () => { next(); startAuto(); });
  if (prevBtn) prevBtn.addEventListener('click', () => { prev(); startAuto(); });

  dots.forEach(dot => {
    dot.addEventListener('click', (e) => {
      current = parseInt(e.target.dataset.index);
      update();
      startAuto();
    });
  });

  function startAuto() { clearInterval(interval); interval = setInterval(next, delay); }

  startAuto();
  update();
})();
</script>

