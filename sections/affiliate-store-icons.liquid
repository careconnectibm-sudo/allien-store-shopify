{% comment %}
  ═══════════════════════════════════════════════════════════════
  Section: Affiliate Store Icons
  File:    sections/affiliate-store-icons.liquid
  Requires: assets/stores-data.js
  ═══════════════════════════════════════════════════════════════
  Shows a responsive icon grid of all affiliate stores loaded
  from stores-data.js. Clicking any icon opens the affiliate
  link in a new tab. Includes live search + category filter.
{% endcomment %}

{{ 'stores-data.js' | asset_url | script_tag }}

<section
  id="asi-{{ section.id }}"
  class="asi-section"
  style="
    --asi-bg:        {{ section.settings.bg_color }};
    --asi-text:      {{ section.settings.text_color }};
    --asi-accent:    {{ section.settings.accent_color }};
    --asi-icon-bg:   {{ section.settings.icon_bg }};
    --asi-icon-size: {{ section.settings.icon_size }}px;
    padding-top:     {{ section.settings.pad_top }}px;
    padding-bottom:  {{ section.settings.pad_bot }}px;
  "
>
  <div class="asi-wrap">

    {%- if section.settings.heading != blank -%}
      <div class="asi-header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="asi-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="asi-heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.subtext != blank -%}
          <p class="asi-subtext">{{ section.settings.subtext }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="asi-controls">
      <div class="asi-search-box">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" id="asi-search-{{ section.id }}" placeholder="{{ section.settings.search_placeholder | default: 'Search 400+ stores…' }}" autocomplete="off">
      </div>
      <div class="asi-filters" id="asi-filters-{{ section.id }}">
        <button class="asi-filter-btn is-active" data-cat="all">All</button>
      </div>
    </div>

    <p class="asi-count" id="asi-count-{{ section.id }}">Loading stores…</p>

    <div class="asi-grid" id="asi-grid-{{ section.id }}"></div>

    <div class="asi-empty" id="asi-empty-{{ section.id }}" style="display:none">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
      <p>No stores match "<strong id="asi-empty-term-{{ section.id }}"></strong>"</p>
      <button class="asi-reset-btn" id="asi-reset-{{ section.id }}">Clear filters</button>
    </div>

    {% if section.settings.show_view_all %}
      <div class="asi-footer">
        <a href="{{ section.settings.view_all_url | default: '/pages/stores' }}" class="asi-view-all-btn">
          {{ section.settings.view_all_label | default: 'View All Stores' }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12,5 19,12 12,19"/></svg>
        </a>
      </div>
    {% endif %}

  </div>
</section>

<style>
/* ─── Affiliate Store Icons Section ─────────────────────────── */
.asi-section {
  background: var(--asi-bg, #f9f9f9);
  color: var(--asi-text, #1a1a1a);
}
.asi-wrap {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 20px;
}

/* Header */
.asi-header { text-align: center; margin-bottom: 32px; }
.asi-eyebrow {
  font-size: .72rem; font-weight: 700;
  letter-spacing: .2em; text-transform: uppercase;
  color: var(--asi-accent, #e63946); margin: 0 0 8px;
}
.asi-heading {
  font-size: clamp(1.5rem, 3vw, 2.2rem);
  font-weight: 700; margin: 0 0 10px;
  color: var(--asi-text, #1a1a1a);
}
.asi-subtext { font-size: .9rem; color: #777; margin: 0; }

/* Controls */
.asi-controls {
  display: flex; flex-direction: column;
  align-items: center; gap: 16px;
  margin-bottom: 20px;
}
.asi-search-box {
  position: relative; width: 100%; max-width: 380px;
}
.asi-search-box svg {
  position: absolute; left: 14px; top: 50%;
  transform: translateY(-50%); color: #999; pointer-events: none;
}
.asi-search-box input {
  width: 100%; padding: 11px 16px 11px 42px;
  border: 1.5px solid #e0e0e0; border-radius: 50px;
  font-size: .88rem; background: #fff;
  color: var(--asi-text, #1a1a1a);
  outline: none; transition: border-color .2s;
  box-sizing: border-box;
}
.asi-search-box input:focus { border-color: var(--asi-accent, #e63946); }

/* Filter pills */
.asi-filters {
  display: flex; flex-wrap: wrap;
  justify-content: center; gap: 6px;
}
.asi-filter-btn {
  padding: 6px 14px; border-radius: 50px;
  border: 1.5px solid #ddd; background: #fff;
  font-size: .72rem; font-weight: 600;
  letter-spacing: .05em; cursor: pointer;
  color: #555; transition: all .2s; white-space: nowrap;
}
.asi-filter-btn:hover,
.asi-filter-btn.is-active {
  background: var(--asi-accent, #e63946);
  border-color: var(--asi-accent, #e63946);
  color: #fff;
}

/* Count */
.asi-count {
  text-align: center; font-size: .78rem;
  color: #aaa; margin: 0 0 20px;
}

/* Grid */
.asi-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(var(--asi-icon-size, 80px), 1fr));
  gap: {{ section.settings.gap }}px;
}

/* Store icon card */
.asi-item {
  display: flex; flex-direction: column;
  align-items: center; gap: 5px;
  animation: asiFadeIn .3s ease both;
}
@keyframes asiFadeIn {
  from { opacity: 0; transform: translateY(6px) scale(.96); }
  to   { opacity: 1; transform: none; }
}

.asi-icon-link {
  display: flex; flex-direction: column;
  align-items: center; gap: 5px;
  text-decoration: none; color: inherit;
  width: 100%;
}
.asi-icon-img-wrap {
  width: var(--asi-icon-size, 80px);
  height: var(--asi-icon-size, 80px);
  border-radius: {{ section.settings.border_radius }}px;
  overflow: hidden; background: var(--asi-icon-bg, #fff);
  border: 1.5px solid #ebebeb;
  display: flex; align-items: center; justify-content: center;
  transition: transform .25s cubic-bezier(.34,1.56,.64,1),
              box-shadow .25s ease, border-color .2s;
  box-shadow: 0 1px 4px rgba(0,0,0,.06);
  padding: 0; box-sizing: border-box; flex-shrink: 0;
}
.asi-icon-link:hover .asi-icon-img-wrap,
.asi-icon-link:focus-visible .asi-icon-img-wrap {
  transform: translateY(-5px) scale(1.08);
  box-shadow: 0 10px 24px rgba(0,0,0,.14);
  border-color: var(--asi-accent, #e63946);
}
.asi-icon-img {
  width: 100%; height: 100%;
  object-fit: contain; display: block;
  padding: {{ section.settings.icon_padding }}px;
  box-sizing: border-box;
}
.asi-icon-name {
  font-size: .6rem; text-align: center;
  color: #777; line-height: 1.2;
  max-width: var(--asi-icon-size, 80px);
  overflow: hidden; text-overflow: ellipsis;
  white-space: nowrap; transition: color .2s;
}
.asi-icon-link:hover .asi-icon-name {
  color: var(--asi-accent, #e63946);
}

/* Empty state */
.asi-empty {
  text-align: center; padding: 48px 20px;
  color: #aaa; border: 2px dashed #e8e8e8;
  border-radius: 12px; margin-top: 8px;
}
.asi-empty p { margin: 12px 0; font-size: .9rem; }
.asi-empty strong { color: var(--asi-text, #1a1a1a); }
.asi-reset-btn {
  padding: 9px 22px; border-radius: 50px;
  border: 1.5px solid #ddd; background: #fff;
  font-size: .8rem; font-weight: 600; cursor: pointer;
  transition: all .2s;
}
.asi-reset-btn:hover {
  background: var(--asi-accent, #e63946);
  border-color: var(--asi-accent, #e63946);
  color: #fff;
}

/* Footer */
.asi-footer { text-align: center; margin-top: 40px; }
.asi-view-all-btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 13px 32px; border-radius: 4px;
  border: 2px solid var(--asi-accent, #e63946);
  color: var(--asi-accent, #e63946);
  text-decoration: none; font-size: .82rem;
  font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
  transition: all .25s;
}
.asi-view-all-btn:hover {
  background: var(--asi-accent, #e63946); color: #fff;
}
.asi-view-all-btn svg { transition: transform .2s; }
.asi-view-all-btn:hover svg { transform: translateX(4px); }

@media (max-width: 480px) {
  .asi-controls { gap: 12px; }
}
</style>

<script>
(function () {
  const SEC_ID   = '{{ section.id }}';
  const SHOW_ALL = {{ section.settings.show_inactive | default: false }};
  const SHOW_NAME= {{ section.settings.show_name | default: true }};

  function waitForData(cb) {
    if (window.STORES_DATA) { cb(window.STORES_DATA); return; }
    const t = setInterval(() => {
      if (window.STORES_DATA) { clearInterval(t); cb(window.STORES_DATA); }
    }, 50);
  }

  waitForData(function (rawStores) {
    const stores = SHOW_ALL
      ? rawStores
      : rawStores.filter(s => s.status === 'active');

    const grid     = document.getElementById('asi-grid-' + SEC_ID);
    const filtersEl= document.getElementById('asi-filters-' + SEC_ID);
    const searchEl = document.getElementById('asi-search-' + SEC_ID);
    const countEl  = document.getElementById('asi-count-' + SEC_ID);
    const emptyEl  = document.getElementById('asi-empty-' + SEC_ID);
    const emptyTerm= document.getElementById('asi-empty-term-' + SEC_ID);
    const resetBtn = document.getElementById('asi-reset-' + SEC_ID);

    if (!grid) return;

    // ── Build category list ──────────────────────────────────────
    const catSet = new Set();
    stores.forEach(s => s.categories.forEach(c => catSet.add(c)));
    const cats = ['all', ...Array.from(catSet).sort()];

    cats.slice(1).forEach(cat => {
      const btn = document.createElement('button');
      btn.className = 'asi-filter-btn';
      btn.dataset.cat = cat;
      btn.textContent = cat;
      filtersEl.appendChild(btn);
    });

    // ── State ────────────────────────────────────────────────────
    let activeCat = 'all';
    let searchQ   = '';

    function matchStore(s) {
      const catOk = activeCat === 'all' || s.categories.includes(activeCat);
      const qOk   = !searchQ || s.merchant.toLowerCase().includes(searchQ);
      return catOk && qOk;
    }

    // ── Render ───────────────────────────────────────────────────
    function render() {
      const matched = stores.filter(matchStore);
      grid.innerHTML = '';

      matched.forEach((s, i) => {
        const item = document.createElement('div');
        item.className = 'asi-item';
        item.style.animationDelay = Math.min(i * 18, 400) + 'ms';

        const link = document.createElement('a');
        link.className   = 'asi-icon-link';
        link.href        = s.url;
        link.target      = '_blank';
        link.rel         = 'noopener noreferrer nofollow';
        link.title       = s.merchant;
        link.setAttribute('aria-label', 'Shop at ' + s.merchant);

        const wrap = document.createElement('div');
        wrap.className = 'asi-icon-img-wrap';

        const img = document.createElement('img');
        img.src     = s.logo;
        img.alt     = s.merchant;
        img.className = 'asi-icon-img';
        img.loading = 'lazy';
        img.onerror = function () {
          this.style.display = 'none';
          wrap.style.background = '#f0f0f0';
          const fb = document.createElement('span');
          fb.style.cssText = 'font-size:.55rem;font-weight:700;text-align:center;padding:4px;line-height:1.2;color:#888;';
          fb.textContent = s.merchant.slice(0, 10);
          wrap.appendChild(fb);
        };

        wrap.appendChild(img);
        link.appendChild(wrap);

        if (SHOW_NAME) {
          const name = document.createElement('span');
          name.className = 'asi-icon-name';
          name.textContent = s.merchant;
          link.appendChild(name);
        }

        item.appendChild(link);
        grid.appendChild(item);
      });

      const total = stores.length;
      countEl.textContent = matched.length === total
        ? `Showing all ${total} stores`
        : `${matched.length} of ${total} stores`;

      const noMatch = matched.length === 0;
      emptyEl.style.display = noMatch ? 'block' : 'none';
      if (emptyTerm) emptyTerm.textContent = searchQ || activeCat;
      grid.style.display = noMatch ? 'none' : 'grid';
    }

    // ── Events ───────────────────────────────────────────────────
    filtersEl.addEventListener('click', e => {
      const btn = e.target.closest('.asi-filter-btn');
      if (!btn) return;
      filtersEl.querySelectorAll('.asi-filter-btn').forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      activeCat = btn.dataset.cat;
      render();
    });

    let debounce;
    if (searchEl) {
      searchEl.addEventListener('input', () => {
        clearTimeout(debounce);
        debounce = setTimeout(() => {
          searchQ = searchEl.value.trim().toLowerCase();
          render();
        }, 180);
      });
    }

    if (resetBtn) {
      resetBtn.addEventListener('click', () => {
        searchQ = ''; activeCat = 'all';
        if (searchEl) searchEl.value = '';
        filtersEl.querySelectorAll('.asi-filter-btn').forEach((b, i) =>
          b.classList.toggle('is-active', i === 0));
        render();
      });
    }

    render();
  });
})();
</script>

{% schema %}
{
  "name": "Affiliate Store Icons",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "text",  "id": "eyebrow",  "label": "Eyebrow label", "default": "Affiliate Partners" },
    { "type": "text",  "id": "heading",  "label": "Heading",       "default": "Shop Our Partner Stores" },
    { "type": "textarea","id":"subtext", "label": "Subtext",        "default": "Click any store logo to shop and earn cashback." },
    { "type": "header", "content": "Search & Filter" },
    { "type": "text",  "id": "search_placeholder", "label": "Search placeholder", "default": "Search 400+ stores…" },
    { "type": "header", "content": "Icon Display" },
    { "type": "range", "id": "icon_size", "label": "Icon size (px)", "min": 56, "max": 120, "step": 4, "default": 80 },
    { "type": "range", "id": "icon_padding","label":"Icon inner padding", "min": 4,"max": 20,"step": 2,"default": 8 },
    { "type": "range", "id": "border_radius","label":"Border radius (px)","min": 0,"max": 60,"step": 4,"default": 12 },
    { "type": "range", "id": "gap",       "label": "Gap (px)",       "min": 6, "max": 32, "step": 2, "default": 12 },
    { "type": "checkbox","id":"show_name","label":"Show store name below icon","default": true },
    { "type": "checkbox","id":"show_inactive","label":"Also show inactive stores","default": false },
    { "type": "header", "content": "View All Button" },
    { "type": "checkbox","id":"show_view_all","label":"Show View All button","default": true },
    { "type": "text",  "id": "view_all_label","label":"Button label","default": "View All Stores" },
    { "type": "url",   "id": "view_all_url",  "label":"Button URL (leave blank for /pages/stores)" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color",    "label": "Section background", "default": "#f9f9f9" },
    { "type": "color", "id": "text_color",  "label": "Text color",         "default": "#1a1a1a" },
    { "type": "color", "id": "accent_color","label": "Accent / hover",     "default": "#e63946" },
    { "type": "color", "id": "icon_bg",     "label": "Icon background",    "default": "#ffffff" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "pad_top", "label": "Padding top (px)",    "min": 0,"max": 120,"step": 4,"default": 64 },
    { "type": "range", "id": "pad_bot", "label": "Padding bottom (px)", "min": 0,"max": 120,"step": 4,"default": 64 }
  ],
  "presets": [{ "name": "Affiliate Store Icons", "category": "Promotions" }]
}
{% endschema %}
