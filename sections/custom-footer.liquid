{% comment %}
  ═══════════════════════════════════════════════════════════════
  Section: AllienStore Custom Footer
  File:    sections/custom-footer.liquid
  Inspired by: allien-store.netlify.app
  ═══════════════════════════════════════════════════════════════
{% endcomment %}

{{ 'stores-data.js' | asset_url | script_tag }}

<footer class="allien-footer" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="footer-container">
    <div class="footer-grid">
      
      <!-- Column 1: Brand -->
      <div class="footer-col brand-col">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="footer-logo">
        {%- else -%}
          <h2 class="footer-logo-text">{{ shop.name }}</h2>
        {%- endif -%}
        <p class="brand-desc">{{ section.settings.description }}</p>
      </div>

      <!-- Column 2: Quick Links -->
      <div class="footer-col">
        <h3 class="footer-title">Quick Links</h3>
        <ul class="footer-links">
          <li><a href="/?view=stores">All Stores</a></li>
          <li><a href="/search">Daily Coupons</a></li>
          <li><a href="/account">Dashboard</a></li>
          <li><a href="/pages/contact">About Us</a></li>
        </ul>
      </div>

      <!-- Column 3: Top Categories -->
      <div class="footer-col categories-col">
        <h3 class="footer-title">Top Categories</h3>
        <div id="footer-categories" class="footer-cat-grid">
          <!-- Populated by JS -->
        </div>
      </div>

    </div>

    <div class="footer-bottom">
      <div class="footer-bottom-inner">
        <p>&copy; {{ 'now' | date: "%Y" }}, {{ shop.name }}. All rights reserved.</p>
        <div class="footer-bottom-links">
          <a href="/pages/privacy-policy">Privacy Policy</a>
          <a href="/pages/terms-of-service">Terms of Service</a>
          <a href="/pages/contact">Contact Us</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
.allien-footer {
  padding: 80px 0 20px;
  font-family: inherit;
  border-top: 3px solid #fc2779;
  background: linear-gradient(180deg, #1a1030 0%, #13091f 100%);
}
.footer-container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 40px;
}
.footer-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr 2fr;
  gap: 60px;
  margin-bottom: 60px;
}
.footer-col {
  display: flex;
  flex-direction: column;
}
.footer-logo {
  max-width: 180px;
  margin-bottom: 20px;
}
.footer-logo-text {
  font-size: 1.8rem;
  font-weight: 800;
  margin: 0 0 20px;
  color: #fff;
}
.brand-desc {
  font-size: 0.95rem;
  line-height: 1.6;
  opacity: 0.7;
  max-width: 320px;
}
.footer-title {
  font-size: 1.1rem;
  font-weight: 700;
  margin: 0 0 25px;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.footer-links {
  list-style: none;
  padding: 0;
  margin: 0;
}
.footer-links li {
  margin-bottom: 12px;
}
.footer-links a {
  color: inherit;
  text-decoration: none;
  font-size: 0.95rem;
  opacity: 0.7;
  transition: opacity 0.2s, color 0.2s;
}
.footer-links a:hover {
  opacity: 1;
  color: #fc2779;
}

.footer-cat-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px 20px;
}
.footer-cat-link {
  font-size: 0.9rem;
  text-decoration: none;
  color: inherit;
  opacity: 0.6;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  transition: opacity 0.2s, color 0.2s;
}
.footer-cat-link:hover {
  opacity: 1;
  color: #fc2779;
}

.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.1);
  padding-top: 30px;
}
.footer-bottom-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.85rem;
  opacity: 0.5;
}
.footer-bottom-links {
  display: flex;
  gap: 25px;
}
.footer-bottom-links a {
  color: inherit;
  text-decoration: none;
}
.footer-bottom-links a:hover {
  text-decoration: underline;
}

@media (max-width: 1024px) {
  .footer-grid { grid-template-columns: 1fr 1fr; }
  .categories-col { grid-column: span 2; }
}
@media (max-width: 768px) {
  .footer-grid { grid-template-columns: 1fr; gap: 40px; }
  .categories-col { grid-column: span 1; }
  .footer-bottom-inner { flex-direction: column; gap: 20px; text-align: center; }
  .footer-container { padding: 0 20px; }
}
</style>

<script>
(function() {
  function renderFooterCats(stores) {
    const container = document.getElementById('footer-categories');
    if (!container) return;

    const catCounts = {};
    stores.forEach(s => {
      s.categories.forEach(c => {
        catCounts[c] = (catCounts[c] || 0) + 1;
      });
    });

    const sortedCats = Object.keys(catCounts).sort((a,b) => catCounts[b] - catCounts[a]).slice(0, 14);
    
    sortedCats.forEach(cat => {
      const a = document.createElement('a');
      a.href = `/?view=stores&cat=${encodeURIComponent(cat)}`;
      a.className = 'footer-cat-link';
      a.textContent = cat;
      container.appendChild(a);
    });
  }

  function waitForData() {
    if (window.STORES_DATA) {
      renderFooterCats(window.STORES_DATA);
    } else {
      setTimeout(waitForData, 100);
    }
  }
  waitForData();
})();
</script>

{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer Logo"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Brand Description",
      "default": "Shop smart and earn rewards on every purchase. We partner with the world's leading brands to bring you the best deals and cashback offers."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1a202c"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#cbd5e0"
    }
  ]
}
{% endschema %}
