{% comment %}
  ═══════════════════════════════════════════════════════════════
  Section: Custom Product Slider
  File:    sections/custom-product-slider.liquid
  ═══════════════════════════════════════════════════════════════
  A premium product carousel with swipe support and Quick Add.
{% endcomment %}

<section
  id="cps-{{ section.id }}"
  class="cps-section"
  style="
    --cps-bg: {{ section.settings.bg_color }};
    --cps-text: {{ section.settings.text_color }};
    --cps-accent: {{ section.settings.accent_color }};
    padding-top: {{ section.settings.pad_top }}px;
    padding-bottom: {{ section.settings.pad_bot }}px;
  "
>
  <div class="cps-container">
    {%- if section.settings.heading != blank -%}
      <div class="cps-header">
        <h2 class="cps-heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="cps-subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="cps-slider-wrapper">
      <button class="cps-nav-btn cps-prev" aria-label="Previous products" id="cps-prev-{{ section.id }}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      <div class="cps-slider" id="cps-slider-{{ section.id }}">
        {%- assign collection = section.settings.collection -%}
        {%- for product in collection.products limit: section.settings.max_products -%}
          <div class="cps-product-card">
            <div class="cps-image-wrap">
              <a href="{{ product.url }}" class="cps-image-link">
                <img
                  src="{{ product.featured_media | image_url: width: 600 }}"
                  alt="{{ product.title | escape }}"
                  class="cps-image primary"
                  loading="lazy"
                  width="400"
                  height="400"
                >
                {%- if product.media[1] != blank and section.settings.show_second_image -%}
                  <img
                    src="{{ product.media[1] | image_url: width: 600 }}"
                    alt="{{ product.title | escape }}"
                    class="cps-image secondary"
                    loading="lazy"
                    width="400"
                    height="400"
                  >
                {%- endif -%}
              </a>

              {%- if product.compare_at_price > product.price -%}
                <span class="cps-badge sale">Sale</span>
              {%- endif -%}
              {%- if product.tags contains 'new' -%}
                <span class="cps-badge new">New</span>
              {%- endif -%}

              {%- if section.settings.show_quick_add -%}
                <button
                  class="cps-quick-add"
                  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                  {% unless product.available %}disabled{% endunless %}
                >
                  {%- if product.available -%}
                    Add to Cart
                  {%- else -%}
                    Sold Out
                  {%- endif -%}
                </button>
              {%- endif -%}
            </div>

            <div class="cps-info">
              <a href="{{ product.url }}" class="cps-title">{{ product.title }}</a>
              <div class="cps-price">
                {%- if product.compare_at_price > product.price -%}
                  <span class="cps-price-compare">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
                <span class="cps-price-current">{{ product.price | money }}</span>
              </div>
            </div>
          </div>
        {%- else -%}
          {%- for i in (1..4) -%}
            <div class="cps-product-card">
              <div class="cps-image-wrap placeholder">
                {{ 'product-' | append: i | placeholder_svg_tag }}
              </div>
              <div class="cps-info">
                <p class="cps-title">Example Product {{ i }}</p>
                <div class="cps-price"><span class="cps-price-current">$19.99</span></div>
              </div>
            </div>
          {%- endfor -%}
        {%- endfor -%}
      </div>

      <button class="cps-nav-btn cps-next" aria-label="Next products" id="cps-next-{{ section.id }}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>
</section>

<style>
.cps-section {
  background: var(--cps-bg, #ffffff);
  color: var(--cps-text, #1a1a1a);
}
.cps-container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 20px;
}
.cps-header {
  text-align: center;
  margin-bottom: 40px;
}
.cps-heading {
  font-size: clamp(1.5rem, 4vw, 2.25rem);
  font-weight: 800;
  margin: 0 0 8px;
}
.cps-subheading {
  font-size: 1rem;
  color: #666;
  margin: 0;
}

.cps-slider-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.cps-slider {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: calc(25% - 15px);
  gap: 20px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  padding-bottom: 10px;
  -ms-overflow-style: none;
  scrollbar-width: none;
}
.cps-slider::-webkit-scrollbar { display: none; }

@media (max-width: 1024px) {
  .cps-slider { grid-auto-columns: calc(33.33% - 14px); }
}
@media (max-width: 768px) {
  .cps-slider { grid-auto-columns: calc(50% - 10px); }
}
@media (max-width: 480px) {
  .cps-slider { grid-auto-columns: 100%; }
}

.cps-product-card {
  scroll-snap-align: start;
  display: flex;
  flex-direction: column;
  gap: 15px;
  background: #fff;
  border: 1.5px solid #eee;
  border-radius: 12px;
  overflow: hidden;
  transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s;
}
.cps-product-card:hover {
  transform: translateY(-6px);
  border-color: rgba(252,39,121,0.3);
  box-shadow: 0 12px 28px rgba(252,39,121,0.1);
}

.cps-image-wrap {
  position: relative;
  aspect-ratio: 1/1;
  background: #fcfcfc;
  overflow: hidden;
}
.cps-image-link {
  display: block;
  width: 100%;
  height: 100%;
}
.cps-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: opacity 0.4s ease;
}
.cps-image.secondary {
  position: absolute;
  top: 0;
  left: 0;
  opacity: 0;
}
.cps-image-wrap:hover .cps-image.secondary {
  opacity: 1;
}

.cps-badge {
  position: absolute;
  top: 10px;
  left: 10px;
  padding: 4px 10px;
  border-radius: 4px;
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
}
.cps-badge.sale {
  background: linear-gradient(90deg, #fc2779, #e91e8c);
  color: #fff;
  box-shadow: 0 2px 8px rgba(252,39,121,0.4);
}
.cps-badge.new {
  background: #2874f0;
  color: #fff;
}

.cps-quick-add {
  position: absolute;
  bottom: 10px;
  left: 10px;
  right: 10px;
  padding: 10px;
  background: rgba(255,255,255,0.95);
  border: 1.5px solid #e0c8d8;
  border-radius: 8px;
  font-size: 0.8rem;
  font-weight: 700;
  cursor: pointer;
  transform: translateY(100%);
  opacity: 0;
  transition: all 0.3s ease;
  color: #fc2779;
}
.cps-image-wrap:hover .cps-quick-add {
  transform: translateY(0);
  opacity: 1;
}
.cps-quick-add:hover {
  background: linear-gradient(90deg, #fc2779, #e91e8c);
  color: #fff;
  border-color: #fc2779;
  box-shadow: 0 4px 16px rgba(252,39,121,0.35);
}

.cps-info {
  padding: 0 15px 15px;
  text-align: center;
}
.cps-title {
  display: block;
  font-size: 0.9rem;
  font-weight: 600;
  color: inherit;
  text-decoration: none;
  margin-bottom: 5px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.cps-price { display: flex; justify-content: center; align-items: center; gap: 10px; font-size: 0.9rem; }
.cps-price-current { font-weight: 800; color: #fc2779; }
.cps-price-compare { text-decoration: line-through; color: #bbb; font-size: 0.8rem; }

/* Navigation */
.cps-nav-btn {
  position: absolute;
  z-index: 10;
  background: #fff;
  border: 1.5px solid #e0c8d8;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 4px 14px rgba(0,0,0,0.1);
  transition: all 0.3s ease;
  color: #fc2779;
}
.cps-prev { left: -22px; }
.cps-next { right: -22px; }
.cps-nav-btn:hover {
  background: linear-gradient(90deg, #fc2779, #e91e8c);
  color: #fff;
  border-color: #fc2779;
  box-shadow: 0 6px 20px rgba(252,39,121,0.35);
  transform: scale(1.1);
}
@media (max-width: 768px) {
  .cps-nav-btn { display: none; }
}

.cps-image-wrap.placeholder svg {
  width: 100%;
  height: 100%;
  fill: #f0f0f0;
}
</style>

<script>
(function() {
  const SEC_ID = '{{ section.id }}';

  const slider = document.getElementById('cps-slider-' + SEC_ID);
  const btnPrev = document.getElementById('cps-prev-' + SEC_ID);
  const btnNext = document.getElementById('cps-next-' + SEC_ID);

  if (slider) {
    btnPrev && btnPrev.addEventListener('click', () => {
      slider.scrollBy({ left: -slider.offsetWidth, behavior: 'smooth' });
    });
    btnNext && btnNext.addEventListener('click', () => {
      slider.scrollBy({ left: slider.offsetWidth, behavior: 'smooth' });
    });
  }

  // Quick Add implementation
  document.querySelectorAll('#cps-' + SEC_ID + ' .cps-quick-add').forEach(btn => {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      const variantId = this.dataset.variantId;
      if (!variantId) return;

      this.innerText = 'Adding...';
      this.disabled = true;

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
      })
      .then(response => response.json())
      .then(data => {
        this.innerText = 'Added!';
        setTimeout(() => {
          this.innerText = 'Add to Cart';
          this.disabled = false;
        }, 2000);
        // Dispatch event for mini-cart or other components
        document.dispatchEvent(new CustomEvent('cart:updated', { detail: data }));
      })
      .catch(error => {
        console.error('Error:', error);
        this.innerText = 'Error';
        setTimeout(() => {
          this.innerText = 'Add to Cart';
          this.disabled = false;
        }, 2000);
      });
    });
  });
})();
</script>

{% schema %}
{
  "name": "Custom Product Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Add your collection subtext here"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products to show",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "show_second_image",
      "label": "Show second image on hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Show Quick Add button",
      "default": true
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdfdfd"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#fc2779"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "pad_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 64
    },
    {
      "type": "range",
      "id": "pad_bot",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Custom Product Slider",
      "category": "Collection"
    }
  ]
}
{% endschema %}
